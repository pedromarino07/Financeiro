{
  "entities": {
    "usuario": {
      "title": "Usuário",
      "description": "Informações do usuário do sistema",
      "type": "object",
      "properties": {
        "nome": { "type": "string", "description": "Nome completo do usuário" },
        "email": { "type": "string", "format": "email", "description": "E-mail do usuário" },
        "criado_em": { "type": "string", "format": "date-time", "description": "Data de criação da conta" }
      },
      "required": ["nome", "email"]
    },
    "categoria": {
      "title": "Categoria",
      "description": "Categorias de transações financeiras",
      "type": "object",
      "properties": {
        "nome": { "type": "string", "description": "Nome da categoria" },
        "tipo": { "type": "string", "enum": ["receita", "despesa"], "description": "Tipo da categoria" },
        "cor": { "type": "string", "description": "Cor hexadecimal da categoria" }
      },
      "required": ["nome", "tipo"]
    },
    "transacao": {
      "title": "Transação",
      "description": "Registro de entrada ou saída financeira",
      "type": "object",
      "properties": {
        "usuario_id": { "type": "string", "description": "ID do usuário dono da transação" },
        "categoria_id": { "type": "string", "description": "ID da categoria da transação" },
        "descricao": { "type": "string", "description": "Descrição da transação" },
        "valor": { "type": "number", "description": "Valor da transação" },
        "data": { "type": "string", "format": "date", "description": "Data da transação" },
        "tipo": { "type": "string", "enum": ["receita", "despesa", "entrada", "saida"], "description": "Tipo da transação" },
        "criado_em": { "type": "string", "format": "date-time", "description": "Data de criação do registro" }
      },
      "required": ["usuario_id", "descricao", "valor", "data", "tipo"]
    }
  },
  "firestore": {
    "/usuarios/{userId}": {
      "schema": "usuario",
      "description": "Dados do perfil do usuário"
    },
    "/categorias/{categoriaId}": {
      "schema": "categoria",
      "description": "Lista global de categorias"
    },
    "/transacoes/{transacaoId}": {
      "schema": "transacao",
      "description": "Lista global de transações"
    }
  }
}
